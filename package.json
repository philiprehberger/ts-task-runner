{
  "name": "@philiprehberger/task-runner",
  "version": "0.1.2",
  "description": "Task orchestration with dependency resolution and topological execution",
  "keywords": [
    "task",
    "runner",
    "dependency",
    "orchestrate",
    "pipeline",
    "build"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-task-runner.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/philiprehberger/ts-task-runner#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-task-runner/issues"
  }
}
